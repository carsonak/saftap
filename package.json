{
  "name": "SafTap",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "backend:prisma:generate": "pnpm --filter @saftap/backend prisma:generate",
    "backend:prisma:migrate": "pnpm --filter @saftap/backend prisma:migrate",
    "backend:prisma:seed": "pnpm --filter @saftap/backend prisma:seed"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "expo": "^56.0.6"
  }
}
