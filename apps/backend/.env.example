# -----------------------------------------------------------------------------
# Coinbase Developer Platform (CDP) credentials
# Used for interacting with CDP services from the backend.
# -----------------------------------------------------------------------------
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret
CDP_APP_ID=your_cdp_app_id

# -----------------------------------------------------------------------------
# Base network / blockchain configuration
# BASE_SEPOLIA_RPC_URL: RPC endpoint URL for Base Sepolia.
# USDC_CONTRACT_ADDRESS: USDC token contract address on your target network.
# TREASURY_WALLET_ADDRESS: backend treasury wallet public address.
# TREASURY_PRIVATE_KEY: private key for signing treasury transactions.
# -----------------------------------------------------------------------------
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/your_api_key
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
TREASURY_WALLET_ADDRESS=0xYourTreasuryWalletAddress
TREASURY_PRIVATE_KEY=0xYourTreasuryPrivateKey

# -----------------------------------------------------------------------------
# Safaricom Daraja API credentials (typically sandbox during development)
# -----------------------------------------------------------------------------
DARAJA_CONSUMER_KEY=your_daraja_consumer_key
DARAJA_CONSUMER_SECRET=your_daraja_consumer_secret
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=your_daraja_lipa_na_mpesa_passkey

# -----------------------------------------------------------------------------
# Application security and persistence
# JWT_SECRET: secret used to sign/verify JWT tokens.
# DATABASE_URL: database connection string.
# -----------------------------------------------------------------------------
JWT_SECRET=replace_with_a_strong_secret
DATABASE_URL=postgresql://user:password@localhost:5432/saftap

# -----------------------------------------------------------------------------
# Server configuration
# -----------------------------------------------------------------------------
PORT=4000
