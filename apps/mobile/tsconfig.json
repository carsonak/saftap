{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0" ,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "types": [
      "react",
      "react-native"
    ],
    "noEmit": true,
    "paths": {
      "@SafTap/shared": [ "../../packages/shared/src" ],
      "@SafTap/shared/*": [ "../../packages/shared/src/*" ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
